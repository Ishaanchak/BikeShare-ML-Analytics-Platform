# Airflow container UID (Linux hosts: set to `id -u`; macOS/Windows: leave as 50000)
AIRFLOW_UID=50000

# Airflow web UI admin account (created on first `docker compose up`)
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# Bikeshare application database (separate from Airflow's own metadata DB)
BIKESHARE_DB_HOST=bikeshare-postgres
BIKESHARE_DB_PORT=5432
BIKESHARE_DB_NAME=bikeshare
BIKESHARE_DB_USER=bikeshare
BIKESHARE_DB_PASSWORD=bikeshare

# GBFS auto-discovery URL for Citi Bike NYC (do not hardcode sub-feed URLs, resolve at runtime)
GBFS_DISCOVERY_URL=https://gbfs.citibikenyc.com/gbfs/gbfs.json

# Historical trip data (Lyft-standard schema, public S3 bucket, no auth)
TRIPDATA_BASE_URL=https://s3.amazonaws.com/tripdata
# How many trailing months to ingest on backfill (config, not hardcoded)
TRIPDATA_LOOKBACK_MONTHS=12

# Model version identifier scheme (timestamp-based by default; override for reproducible runs)
MODEL_VERSION=
